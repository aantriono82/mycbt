PORT=8080
# Comma-separated list. Use "*" only if you know what you're doing.
CORS_ORIGINS=http://localhost:5173
GIN_MODE=debug
APP_URL=http://localhost:8080

# PostgreSQL
# Example:
# DATABASE_URL=postgres://atigacbt:atigacbt@localhost:5433/atigacbt?sslmode=disablepostgres://atigacbt:atigacbt@localhost:5433/atigacbt?sslmode=disable
DATABASE_URL=postgres://atigacbt:atigacbt@localhost:5433/atigacbt?sslmode=disable

# Redis (optional, recommended for production)
# REDIS_ADDR=localhost:6379
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=atigacbt

# Upload storage:
# - local (default): save to UPLOAD_LOCAL_DIR and serve via /uploads
# - rustfs: save objects to RustFS (S3-compatible) bucket
UPLOAD_PROVIDER=local
UPLOAD_LOCAL_DIR=uploads
RUSTFS_ENDPOINT=
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_BUCKET=
RUSTFS_USE_SSL=false
RUSTFS_PUBLIC_BASE_URL=
RUSTFS_KEY_PREFIX=

# Backward compatibility (optional, legacy names)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=
MINIO_PUBLIC_BASE_URL=
MINIO_KEY_PREFIX=

# JWT auth (M1)
# Generate with: openssl rand -hex 32
JWT_SECRET=8348169545be447f
JWT_ISSUER=atigacbt
# Access token TTL in minutes
JWT_TTL_MINUTES=120

# Optional seed (used by cmd/seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-seed
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com

# OAuth / email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

PORT=8080
# Comma-separated list. Use "*" only if you know what you're doing.
CORS_ORIGINS=http://localhost:5173
GIN_MODE=debug

# PostgreSQL
# Example:
# DATABASE_URL=postgres://mycbt:mycbt@localhost:5433/mycbt?sslmode=disable
DATABASE_URL=

# Redis (optional, recommended for production)
# REDIS_ADDR=localhost:6379
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=mycbt

# Upload storage:
# - local (default): save to UPLOAD_LOCAL_DIR and serve via /uploads
# - minio: save objects to MinIO bucket
UPLOAD_PROVIDER=local
UPLOAD_LOCAL_DIR=uploads
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=
MINIO_KEY_PREFIX=

# JWT auth (M1)
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ISSUER=mycbt
# Access token TTL in minutes
JWT_TTL_MINUTES=120

# Optional seed (used by cmd/seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
